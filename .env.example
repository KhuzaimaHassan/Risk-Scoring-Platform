# ============================================================
# .env.example — copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# --- Application ---
APP_NAME="Risk Scoring Platform"
APP_VERSION="0.1.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=false
API_PREFIX=/api/v1

# --- PostgreSQL ---
DB_HOST=localhost                # Use "postgres" inside Docker network
DB_PORT=5432
DB_NAME=risk_scoring
DB_USER=risk_user
DB_PASSWORD=changeme             # ← CHANGE THIS
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false                    # Set true for SQL query logging (dev only)

# --- Model Registry ---
MODEL_ARTIFACT_DIR=models
MODEL_REPORT_DIR=reports
ACTIVE_MODEL_NAME=fraud_classifier

# --- Feature Windows (in minutes) ---
FEATURE_WINDOW_1H_MINUTES=60
FEATURE_WINDOW_24H_MINUTES=1440
FEATURE_WINDOW_7D_MINUTES=10080

# --- Prediction ---
DEFAULT_DECISION_THRESHOLD=0.5
MAX_BATCH_SIZE=500

# --- Monitoring & Drift ---
DRIFT_PSI_THRESHOLD_WARNING=0.1
DRIFT_PSI_THRESHOLD_CRITICAL=0.2
DRIFT_KS_P_VALUE_THRESHOLD=0.05
MONITORING_WINDOW_HOURS=24
PERFORMANCE_F1_MIN_THRESHOLD=0.70

# --- Retraining ---
RETRAINING_MIN_SAMPLES=10000
RETRAINING_AUTO_PROMOTE=false

# --- Security ---
SECRET_KEY=change-this-in-production  # ← CHANGE THIS in prod
ALLOWED_ORIGINS=["http://localhost:3000"]
